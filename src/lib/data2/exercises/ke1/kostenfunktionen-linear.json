        "name": "Lineare Gesamtkostenfunktion",
        "math": "K_T(M) = K_f + k_v \\cdot M",
        "result": { "symbol": "K_T(M)", "description": "Gesamtkosten in Abhängigkeit der Ausbringungsmenge" },
        "params": [
          { "symbol": "K_f", "description": "Fixe Kosten (beschäftigungsunabhängig)" },
          { "symbol": "k_v", "description": "Variable Stückkosten (konstant bei linearem Verlauf)" },
          { "symbol": "M",   "description": "Ausbringungsmenge" }
        ]
      },
      {
        "id": "totale-stueckkosten",
        "name": "Totale Stückkosten",
        "math": "k_T(M) = \\frac{K_T(M)}{M} = \\frac{K_f}{M} + k_v",
        "result": { "symbol": "k_T(M)", "description": "Durchschnittliche Gesamtkosten pro Stück" },
        "params": [
          { "symbol": "K_f", "description": "Fixe Kosten" },
          { "symbol": "k_v", "description": "Variable Stückkosten" },
          { "symbol": "M",   "description": "Ausbringungsmenge" }
        ]
      },
      {
        "id": "fixe-stueckkosten",
        "name": "Fixe Stückkosten",
        "math": "k_f(M) = \\frac{K_f}{M}",
        "result": { "symbol": "k_f(M)", "description": "Fixkosten pro Stück (Fixkostendegression)" },
        "params": [
          { "symbol": "K_f", "description": "Fixe Kosten" },
          { "symbol": "M",   "description": "Ausbringungsmenge" }
        ]
      },
      {
