            "steps": [
              {
                "type": "formula",
                "title": "Lineare Kostenfunktion für beide Beobachtungen",
                "description": "Es gilt $K_T(M) = K_f + k_v \\cdot M$ für beide Punkte:",
                "math": "\\begin{cases} K_{T,1} = K_f + k_v \\cdot M_1 \\\\ K_{T,2} = K_f + k_v \\cdot M_2 \\end{cases}"
              },
              {
                "type": "calculation",
                "title": "Differenz bilden (Fixkosten eliminieren)",
                "math": "K_{T,2} - K_{T,1} = k_v \\cdot (M_2 - M_1)"
              },
              {
                "type": "substitution",
                "title": "Werte einsetzen",
                "math": "9{.}000 - 5{.}000 = k_v \\cdot (300 - 100)"
              },
              {
                "type": "calculation",
                "title": "Nach $k_v$ auflösen",
                "math": "k_v = \\frac{4{.}000}{200}"
              },
              {
                "type": "result",
                "title": "Variable Stückkosten",
                "math": "k_v = 20 \\text{ GE/ME}"
              }
            ]
          },
          {
            "label": "b",
            "question": "Bestimmen Sie die fixen Kosten $K_f$.",
            "formulaRefs": ["gesamtkosten-linear"],
            "steps": [
              {
                "type": "formula",
                "title": "Kostenfunktion nach $K_f$ umstellen",
                "math": "K_f = K_{T,1} - k_v \\cdot M_1"
              },
              {
                "type": "substitution",
                "title": "Werte einsetzen",
                "math": "K_f = 5{.}000 - 20 \\cdot 100"
              },
              {
                "type": "calculation",
                "title": "Ausrechnen",
                "math": "K_f = 5{.}000 - 2{.}000"
              },
              {
                "type": "result",
                "title": "Fixe Kosten",
                "math": "K_f = 3{.}000 \\text{ GE}"
              }
            ]
          },
          {
            "label": "c",
            "question": "Geben Sie die gesamte Kostenfunktion $K_T(M)$ an.",
            "formulaRefs": ["gesamtkosten-linear"],
            "steps": [
              {
                "type": "formula",
                "title": "Lineare Kostenfunktion",
