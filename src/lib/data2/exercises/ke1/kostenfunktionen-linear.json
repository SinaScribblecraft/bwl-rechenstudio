              {
                "type": "formula",
                "title": "Grenzkosten als erste Ableitung",
                "math": "K'_T(M) = \\frac{dK_T(M)}{dM} = \\frac{d(K_f + k_v \\cdot M)}{dM}"
              },
              {
                "type": "calculation",
                "title": "Ableitung bilden",
                "description": "Die Ableitung der fixen Kosten ist null, da diese beschäftigungsunabhängig sind.",
