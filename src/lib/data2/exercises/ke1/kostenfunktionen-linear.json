        "name": "Grenzkosten bei linearem Verlauf",
        "math": "K'_T(M) = \\frac{dK_T(M)}{dM} = k_v",
        "result": { "symbol": "K'_T(M)", "description": "Steigung der Gesamtkostenfunktion" },
        "params": [
          { "symbol": "k_v", "description": "Variable Stückkosten — entsprechen bei linearem Verlauf den Grenzkosten" }
        ]
      }
    ],
    "exercises": [
      {
