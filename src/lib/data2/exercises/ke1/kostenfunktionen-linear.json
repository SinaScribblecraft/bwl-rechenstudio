            "steps": [
              {
                "type": "formula",
                "title": "Totale Stückkosten",
                "math": "k_T(M) = \\frac{K_T(M)}{M} = \\frac{K_f}{M} + k_v"
              },
              {
                "type": "substitution",
                "title": "Werte einsetzen",
                "math": "k_T(2{.}000) = \\frac{20{.}000}{2{.}000} + 8"
              },
              {
                "type": "calculation",
                "title": "Ausrechnen",
