          {
            "label": "a",
            "question": "Bestimmen Sie die Grenzrate der Substitution $GRS_{2,1}$ und ermitteln Sie anschließend den Expansionspfad. Geben Sie dazu die Beziehung an, die im Kostenminimum zwischen $GRS_{2,1}$ und den Faktorpreisen $q_1$ und $q_2$ gilt.",
            "formulaRefs": ["isoquante", "grs", "minimalkosten-bedingung"],
            "steps": [
              {
                "type": "formula",
                "title": "Produktionsfunktion",
                "math": "M = 4 r_1^2 \\cdot r_2"
              },
              {
                "type": "calculation",
                "title": "Nach $r_2$ auflösen (Isoquantengleichung)",
                "math": "r_2 = \\frac{M}{4 r_1^2} = \\frac{M}{4} \\cdot r_1^{-2}"
              },
              {
                "type": "calculation",
                "title": "Ableiten nach $r_1$ — Grenzrate der Substitution",
                "math": "GRS_{2,1} = \\frac{dr_2}{dr_1} = -\\frac{M}{2 r_1^3}"
              },
              {
                "type": "formula",
                "title": "Optimalitätsbedingung im Kostenminimum",
                "math": "\\frac{dr_2}{dr_1} = -\\frac{q_1}{q_2}"
              },
              {
                "type": "substitution",
                "title": "GRS und Faktorpreise gleichsetzen",
                "math": "-\\frac{M}{2 r_1^3} = -\\frac{6}{4} = -\\frac{3}{2}"
              },
              {
                "type": "calculation",
                "title": "$M$ durch Produktionsfunktion ersetzen ($M = 4 r_1^2 \\cdot r_2$)",
                "math": "\\frac{4 r_1^2 \\cdot r_2}{2 r_1^3} = \\frac{3}{2}"
              },
              {
                "type": "calculation",
                "title": "Vereinfachen",
                "math": "\\frac{2 r_2}{r_1} = \\frac{3}{2}"
              },
              {
                "type": "result",
                "title": "Expansionspfad",
                "math": "r_2 = \\frac{3}{4} \\cdot r_1"
              }
