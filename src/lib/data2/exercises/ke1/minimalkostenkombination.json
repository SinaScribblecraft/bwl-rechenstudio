        ]
      },
      {
        "id": "grs",
        "name": "Grenzrate der Substitution",
        "math": "GRS_{2,1} = \\frac{dr_2}{dr_1} = -\\frac{\\partial M / \\partial r_1}{\\partial M / \\partial r_2}",
        "result": { "symbol": "GRS_{2,1}", "description": "Marginales Faktoraustauschverhältnis entlang der Isoquante" },
