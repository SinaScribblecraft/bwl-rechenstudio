        ]
      },
      {
        "id": "andler",
        "name": "Andler-Formel",
        "math": "y^{opt} = \\sqrt{\\frac{2 \\cdot R \\cdot C_r}{C_l}}",
        "result": {
          "symbol": "y^{opt}",
          "description": "Kostenminimale Bestellmenge"
        },
        "params": [
          { "symbol": "R",   "description": "Gesamtbedarf im Planungszeitraum T (ME)" },
          { "symbol": "C_r", "description": "Bestellfixe Kosten pro Bestellung (GE)" },
          { "symbol": "C_l", "description": "Lagerkostensatz (GE/(ME·ZE))" }
        ]
      },
      {
        "id": "bestellhaeufigkeit",
        "name": "Optimale Bestellhäufigkeit",
        "math": "n^{opt} = \\frac{R}{y^{opt}}",
        "result": {
          "symbol": "n^{opt}",
          "description": "Anzahl der Bestellungen im Planungszeitraum"
        },
        "params": [
          { "symbol": "R",        "description": "Gesamtbedarf" },
          { "symbol": "y^{opt}", "description": "Optimale Bestellmenge" }
        ]
      },
      {
        "id": "lagerzykluszeit",
        "name": "Optimale Lagerzykluszeit",
        "math": "t^{opt} = \\frac{y^{opt}}{V}",
        "result": {
          "symbol": "t^{opt}",
          "description": "Zeit zwischen zwei aufeinanderfolgenden Bestellungen"
        },
        "params": [
          { "symbol": "y^{opt}", "description": "Optimale Bestellmenge" },
          { "symbol": "V",       "description": "Bedarfsrate pro Zeiteinheit" }
        ]
      },
      {
        "id": "lagerkosten",
        "name": "Lagerkosten",
        "math": "K_L(y) = \\frac{y}{2} \\cdot C_l \\cdot T",
        "result": {
          "symbol": "K_L",
          "description": "Lagerkosten im Planungszeitraum"
        },
        "params": [
          { "symbol": "y",   "description": "Bestellmenge" },
