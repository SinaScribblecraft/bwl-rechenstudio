{
  "andler": {
    "title": "Optimale Bestellmenge (Andler)",
    "subtitle": "Bestimme die kostenminimale Bestellmenge sowie Lager- und Bestellkosten.",

    "formulas": [
      {
        "id": "lagerkostensatz",
        "name": "Lagerkostensatz",
        "math": "C_l = b \\cdot i + C_{lm}",
